{
  "opml_file": "subscriptions.opml",
  "output_dir": "public_html",
  "db_path": "feeds.db",
  "days_back": 1,
  "feed_timeout": 10,
  "category_order": [
    "Favorite Blogs",
    "RPGs"
  ],
  "timezone": "America/New_York",
  "obsidian": {
    "vault": "My Vault",
    "folder": "Clippings"
  },
  "summarizer_endpoint": "/summarizer/summarize/text",
  "retention_days": 90
}
